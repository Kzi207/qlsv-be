# =========================================================
# QLSV Backend Environment
# Copy file nay thanh: backend/.env
# Luu y: Khong commit file .env that len Git.
# =========================================================


# =========================================================
# 1) BAT BUOC - DATABASE
# =========================================================

# Chuoi ket noi PostgreSQL cho Prisma.
# Vi du local:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qlsv?schema=public
# Vi du deploy co SSL:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require


# =========================================================
# 2) BAT BUOC - BAO MAT DANG NHAP
# =========================================================

# Khoa ky JWT. Bat buoc phai dai, ngau nhien, toi thieu 32 ky tu.
# Nen tao bang password manager hoac lenh sinh random cua he dieu hanh.
JWT_SECRET=replace_with_a_strong_secret_at_least_32_chars

# Domain frontend duoc phep goi API. Dung cho CORS va cookie.
# Local:
# FRONTEND_ORIGIN=http://localhost:5173
# Production:
# FRONTEND_ORIGIN=https://your-frontend.vercel.app
# Neu co nhieu origin, phan cach bang dau phay.
FRONTEND_ORIGIN=http://localhost:5173


# =========================================================
# 3) RUNTIME
# =========================================================

# development: hien loi ro hon khi dev.
# production: an loi noi bo, bat security headers chat hon.
NODE_ENV=development

# Cong backend lang nghe. Mac dinh trong code la 5000.
PORT=5000


# =========================================================
# 4) COOKIE / SESSION
# =========================================================

# SameSite cho cookie dang nhap.
# Local cung site: lax
# Frontend/backend khac domain HTTPS (Vercel + Render): none
COOKIE_SAME_SITE=lax

# Bat secure cookie.
# Local HTTP: false
# Production HTTPS, dac biet khi COOKIE_SAME_SITE=none: true
COOKIE_SECURE=false

# Tuy chon: domain cookie dung khi frontend/backend cung parent domain.
# Vi du: .example.com
# Bo trong neu dung localhost, IP, Vercel/Render khac domain, hoac khong chac.
COOKIE_DOMAIN=

# Cho phep doc token tu query string (?token=...).
# Chi bat khi that su can cho workflow dac biet. Nen giu false trong production.
ALLOW_QUERY_TOKEN_AUTH=false


# =========================================================
# 5) AI CHATBOT - TUY CHON
# =========================================================

# Khoa API Google GenAI/Gemini cho chatbot sinh vien.
# Chi dat o backend, tuyet doi khong dua vao frontend.
# Co the dung GEMINI_API_KEY hoac GOOGLE_GENAI_API_KEY.
GEMINI_API_KEY=
GOOGLE_GENAI_API_KEY=

# Model AI. Neu bo trong code se dung mac dinh gemma-4-31b-it.
GEMINI_MODEL=gemma-4-31b-it


# =========================================================
# 6) EMAIL THONG BAO - TUY CHON
# =========================================================

# Dung Gmail SMTP de gui email thong bao nop/duyet DRL.
# GMAIL_APP_PASSWORD la mat khau ung dung 16 ky tu, khong phai mat khau Gmail thuong.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Dia chi hien thi trong truong From. Neu bo trong se dung GMAIL_USER.
MAIL_FROM=


# =========================================================
# 7) CLOUDFLARE R2 - TUY CHON
# =========================================================

# Dung de luu file minh chung len Cloudflare R2.
# Neu khong cau hinh day du, he thong se khong dung R2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Endpoint S3-compatible cua R2.
# Dang thuong:
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Region mac dinh cua R2 la auto.
R2_REGION=auto

# Thu muc/prefix luu minh chung trong bucket.
R2_EVIDENCE_PREFIX=evidence
