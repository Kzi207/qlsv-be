# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
JWT_SECRET=replace_with_a_strong_secret_at_least_32_chars
FRONTEND_ORIGIN=https://your-frontend.vercel.app

# Runtime
NODE_ENV=production
PORT=5000

# Cookies
# If frontend and backend are on different domains (Vercel + Render), use:
COOKIE_SAME_SITE=none
COOKIE_SECURE=true
# Optional: set only if you use a shared custom parent domain
# COOKIE_DOMAIN=.yourdomain.com

# Auth behavior
# Optional, keep false in production unless you need token in query string
ALLOW_QUERY_TOKEN_AUTH=false

# Optional: email notifications (Gmail SMTP)
# GMAIL_USER=your_email@gmail.com
# GMAIL_APP_PASSWORD=your_16_char_app_password
# MAIL_FROM=your_email@gmail.com

# Optional: Cloudflare R2 storage
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET=your_bucket_name
# R2_REGION=auto
# R2_EVIDENCE_PREFIX=evidence
